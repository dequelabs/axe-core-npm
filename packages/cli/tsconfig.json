{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["dom", "ES2015", "esnext.asynciterable"],
    "module": "commonjs",
    "outDir": "./dist/",
    "target": "ES2015",
    "types": ["node"],
    // We use istanbul ignore comments. They need to be
